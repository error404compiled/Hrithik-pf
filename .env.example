# Optional: when the SPA is served from a different origin than your API (e.g. static hosting + Appwrite / BFF).
# Example: https://hritiksharma.me or https://<region>.cloudfunctions.net/...
# VITE_API_BASE_URL=https://example.com

# Appwrite frontend config (required to avoid /api/* 404 in Vite dev)
# VITE_APPWRITE_ENDPOINT=
# VITE_APPWRITE_PROJECT_ID=
# VITE_ADMIN_EMAIL=
# VITE_APPWRITE_DATABASE_ID=portfolio
# VITE_APPWRITE_CONTACT_COLLECTION_ID=contact_submissions
# VITE_APPWRITE_VIEWS_COLLECTION_ID=post_views
# VITE_APPWRITE_POSTS_COLLECTION_ID=posts

# Optional: Appwrite function URLs (used for contact email notification / custom views handler)
# VITE_APPWRITE_CONTACT_URL=
# VITE_APPWRITE_VIEWS_URL=

# Chat: POST with JSON { messages } → plain text reply (same as former Next /api/chat).
# Vite dev serves POST /api/chat locally when GOOGLE_API_KEY is set (not VITE_* — never exposed to the bundle).
# Production: deploy `back-end/functions/chat` and set this to the function HTTPS URL.
# VITE_APPWRITE_CHAT_URL=https://<region>.cloud.appwrite.io/v1/functions/<id>/executions
GOOGLE_API_KEY=
# Optional: default gemini-2.5-flash-lite (fast / free-tier friendly). Override only if you know the id from ListModels.
# GEMINI_MODEL=gemini-2.5-flash
